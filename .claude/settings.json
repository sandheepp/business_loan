      "Bash(curl -s http://localhost:8502/)",
      "Bash(curl -s \"http://localhost:8502/_stcore/allowed-message-origins\")",
      "Bash(curl -s -o /dev/null -w \"%{http_code}\" http://localhost:8502/application)",
